# ============================================
# 校园论坛 — 环境变量参考模板
# 此文件仅作参考，不会在运行时被读取
# 各服务的实际密钥请放在各自的 .env 文件中
# ============================================

# --- 必需密钥 ---

# DeepSeek AI (ai-service/.env)
DEEPSEEK_KEY=<api_key>

# Tavily 搜索 API (ai-service/.env)
TAVILY_API_KEY=<api_key>

# 163 邮箱 SMTP 授权码 (user-service/.env)
STMP_EMAIL=<email@163.com>
STMP_EMAIL_PASSWORD=<smtp_password>

# 天气 API (forum-service/.env)
WEATHER_KEY=<api_key>

# --- 可选密钥 ---

# SiliconFlow AI (ai-service/.env，图片生成用)
SILICONFLOW_API_KEY=<api_key>

# JWT 签名密钥 (user-service/.env，gateway-service 用系统环境变量)
JWT_KEY=<long-random-jwt-key>

# 服务间调用鉴权 (各服务的 .env)
INTERNAL_SERVICE_TOKEN=<long-random-internal-token>

# --- 可观测性 ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<strong-password>
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACING_SAMPLING_PROBABILITY=1.0
APP_ENV=dev
