logging {
  level  = "info"
  format = "json"
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

local.file_match "applications" {
  path_targets = [
    {
      __path__    = "/var/log/forum/**/*.json",
      environment = "dev",
      job         = "forum-applications",
    },
  ]

  sync_period = "5s"
}

loki.source.file "applications" {
  targets    = local.file_match.applications.targets
  forward_to = [loki.process.applications.receiver]
}

loki.process "applications" {
  stage.json {
    expressions = {
      environment = "environment",
      level       = "level",
      service     = "application",
    }
  }

  stage.labels {
    values = {
      environment = "",
      level       = "",
      service     = "",
    }
  }

  forward_to = [loki.write.local.receiver]
}

discovery.docker "local" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = discovery.docker.local.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    replacement  = "docker"
    target_label = "job"
  }

  rule {
    replacement  = "dev"
    target_label = "environment"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.write.local.receiver]
}

otelcol.receiver.otlp "default" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }

  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"

    tls {
      insecure = true
    }
  }
}
